# index.html — nunca cacheado (força recarga ao deployar nova versão)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets com hash no nome — podem ser cacheados para sempre (hash muda a cada build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Demais arquivos estáticos — cache curto
/*
  Cache-Control: public, max-age=3600
